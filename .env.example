# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=rag_audio_db

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Ollama / RAG ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Text embeddings ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Redis cache (optional) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
QUERY_CACHE_TTL_SECONDS=3600
QUERY_CACHE_MAX_PER_USER=20
QUERY_CACHE_SIMILARITY_THRESHOLD=0.95

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_UPLOAD_DIR=./uploads
MAX_AUDIO_SIZE_MB=50

# ── Whisper ───────────────────────────────────────────────────────────────────
WHISPER_MODEL_SIZE=small
WHISPER_LANGUAGE=en

# ── Speaker pipeline ──────────────────────────────────────────────────────────
ENABLE_SPEAKER_AWARE_PROCESSING=true

# ── User-head storage backend ─────────────────────────────────────────────────
USE_MONGODB_STORAGE=false
DUAL_SAVE_MODE=false
MONGODB_STORAGE_COMPRESSION=gzip
